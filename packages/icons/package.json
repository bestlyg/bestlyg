{
    "name": "@bestlyg/icons",
    "version": "0.0.0",
    "description": "Bestlyg React SVG icon set.",
    "license": "ISC",
    "author": "bestlyg",
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "sideEffects": false,
    "files": [
        "dist",
        "README.md"
    ],
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "default": "./dist/index.js"
        },
        "./svg-icon": {
            "types": "./dist/svg-icon.d.ts",
            "import": "./dist/svg-icon.js",
            "default": "./dist/svg-icon.js"
        },
        "./svg/*": {
            "types": "./dist/svg/*.d.ts",
            "import": "./dist/svg/*.js",
            "default": "./dist/svg/*.js"
        },
        "./package.json": "./package.json"
    },
    "scripts": {
        "dump": "node scripts/dump-svg.mjs -p ~/Downloads/库 && pnpm -w lint && node scripts/update-log.mjs",
        "lint": "tsc --noEmit",
        "lint:ci": "pnpm lint",
        "prepublishOnly": "pnpm build",
        "build": "rimraf dist && tsc",
        "dev": "tsc --watch"
    },
    "dependencies": {
        "clsx": "catalog:",
        "react": "catalog:"
    },
    "devDependencies": {
        "@types/node": "catalog:",
        "@types/react": "catalog:",
        "change-case": "catalog:",
        "consola": "catalog:",
        "dayjs": "catalog:",
        "rimraf": "catalog:",
        "typescript": "catalog:",
        "unbuild": "catalog:",
        "zx": "catalog:"
    }
}
