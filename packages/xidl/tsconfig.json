{
    "compilerOptions": {
        "target": "ESNext",
        "module": "ESNext",
        "ignoreDeprecations": "6.0",
        "allowJs": true,
        "skipLibCheck": true,
        "allowSyntheticDefaultImports": true,
        "lib": ["ESNext"],
        "moduleResolution": "Bundler",
        "esModuleInterop": true,
        "types": ["node"],
        "rootDir": ".",
        "typeRoots": ["./node_modules/@types"],
        "paths": {
            "@/*": ["./src/*"]
        }
    },
    "exclude": ["dist", "output", "xidl.config.ts"]
}
