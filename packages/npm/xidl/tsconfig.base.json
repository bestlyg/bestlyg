{
    "compilerOptions": {
        "ignoreDeprecations": "6.0",
        "target": "ESNext",
        "module": "ESNext",
        "allowJs": true,
        "skipLibCheck": true,
        "allowSyntheticDefaultImports": true,
        "lib": ["ESNext"],
        "moduleResolution": "Bundler",
        "esModuleInterop": true,
        "types": ["node"]
    }
}
