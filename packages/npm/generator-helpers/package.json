{
    "name": "generator-helpers",
    "version": "0.0.2",
    "keywords": [
        "generator"
    ],
    "homepage": "https://github.com/bestlyg/bestlyg/tree/master/packages/npm/xidl",
    "license": "MIT",
    "author": "bestlyg@foxmail.com",
    "files": [
        "package.json",
        "README.md",
        "dist"
    ],
    "type": "module",
    "main": "./dist/index.cjs",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.ts",
    "typesVersions": {
        "*": {
            ".": [
                "./dist/index.d.ts"
            ]
        }
    },
    "exports": {
        ".": {
            "import": {
                "types": "./dist/index.d.mts",
                "default": "./dist/index.mjs"
            },
            "require": {
                "types": "./dist/index.d.cts",
                "default": "./dist/index.cjs"
            }
        }
    },
    "scripts": {
        "prepublishOnly": "pnpm build",
        "build": "rimraf dist && unbuild --config ./node_modules/@bestlyg/core-shared/build.config.ts",
        "dev": "unbuild --config ./node_modules/@bestlyg/core-shared/build.config.ts --watch",
        "test": "vitest"
    },
    "devDependencies": {
        "@bestlyg/core-shared": "workspace:^",
        "@modern-js/module-tools": "catalog:",
        "@types/lodash": "catalog:",
        "@types/node": "catalog:",
        "lodash": "catalog:",
        "rimraf": "catalog:",
        "typescript": "catalog:",
        "unbuild": "catalog:",
        "vite": "catalog:",
        "vitest": "catalog:"
    }
}
