class Solution:
    def isGood(self, nums: List[int]) -> bool:
        if len(nums) == 1: return False
        nums.sort()
        if len(nums) - 1 != nums[-1]: return False
        if nums[-1] != nums[-2]: return False
        for n1, n2 in pairwise(nums[:-1]):
            if n1 + 1 != n2: return False
        return True