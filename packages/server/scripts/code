class Solution:
    def findThePrefixCommonArray(self, A: List[int], B: List[int]) -> List[int]:
        anum = bnum = 0
        res = []
        for i in range(len(A)):
            anum |= 1 << A[i]
            bnum |= 1 << B[i]
            res.append(str(bin(anum & bnum)).count('1'))
        return res