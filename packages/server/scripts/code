class Solution:
    def largestSubmatrix(self, matrix: List[List[int]]) -> int:
        n = len(matrix)
        m = len(matrix[0])
        h = [0] * m
        res = 0
        for i in range(n):
            for j in range(m):
                if matrix[i][j] == 0: h[j] = 0
                else: h[j] += 1
            hh = sorted(h)
            for j in range(m):
                res = max(res, hh[j] * (m - j))
        return res