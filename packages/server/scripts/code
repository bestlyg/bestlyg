class Solution:
    def areSimilar(self, mat: List[List[int]], k: int) -> bool:
        n = len(mat)
        m = len(mat[0])
        for i in range(n):
            if i % 2 == 0:
                for j in range(m):
                    if mat[i][j] != mat[i][(j + m - k) % m]:
                        return False
            else:
                for j in range(m):
                    if mat[i][j] != mat[i][(j + k) % m]:
                        return False
        return True