class Solution:
    def getHappyString(self, n: int, k: int, disable_char = '') -> str:
        if n == 1: 
            if k - 1 >= 3: return ''
            return [c for c in 'abc' if c != disable_char][k - 1]
        cnt = 2 ** (n - 1)
        for ch in 'abc':
            if ch == disable_char: continue
            if cnt < k:
                k -= cnt
            else:
                return ch + self.getHappyString(n - 1, k, ch)
        return ''