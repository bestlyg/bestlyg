class Solution:
    def twoEditWords(self, queries: List[str], dictionary: List[str]) -> List[str]:
        n = len(queries[0])
        res = []
        for q in queries:
            for d in dictionary:
                if sum(q[i] != d[i] for i in range(n)) <= 2:
                    res.append(q)
                    break
        return res