class Solution:
    def numSpecial(self, mat: List[List[int]]) -> int:
        n = len(mat)
        m = len(mat[0])
        return sum(
            mat[i][j] == 1 and sum(mat[i1][j] for i1 in range(n)) + sum(mat[i][j1] for j1 in range(m)) == 2
            for i in range(n)
            for j in range(m)
        )