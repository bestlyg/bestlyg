{
  // 使用 IntelliSense 了解相关属性。
  // 悬停以查看现有属性的描述。
  // 欲了解更多信息，请访问: https://go.microsoft.com/fwlink/?linkid=830387
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Node Server",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "pnpm", // 使用 pnpm 作为运行时
      "runtimeArgs": ["start"], // 传递 start 命令给 pnpm
      "console": "integratedTerminal", // 在集成终端中显示输出
      "skipFiles": ["<node_internals>/**"],
      "cwd": "${workspaceFolder}", // 项目根目录作为工作目录
      "env": {
        "NODE_ENV": "development"
      }
    }
  ]
}
