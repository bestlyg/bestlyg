{
    "name": "@bestlyg/server",
    "version": "0.0.0",
    "private": true,
    "author": "bestlyg",
    "exports": {
        "./package.json": "./package.json",
        "./openapi.json": "./openapi.json",
        "./*": {
            "import": "./*",
            "require": "./*",
            "default": "./*"
        }
    },
    "scripts": {
        "build": "nest build",
        "format": "oxfmt \"src/**/*.ts\" \"test/**/*.ts\" \"libs/**/*.ts\"",
        "start": "cross-env NODE_ENV=development nest start",
        "start:dev": "cross-env NODE_ENV=development nest start --watch",
        "start:debug": "cross-env NODE_ENV=development nest start --debug --watch",
        "start:prod": "cross-env NODE_ENV=production node dist/main",
        "lint": "oxlint --fix \"{src,apps,libs,test}/**/*.ts\"",
        "test": "jest",
        "test:watch": "jest --watch",
        "test:cov": "jest --coverage",
        "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
        "test:e2e": "jest --config ./test/jest-e2e.json",
        "create:problem": "tsx scripts/create-problem.ts",
        "create:ledger": "tsx scripts/create-ledger.ts",
        "create:xuan": "tsx scripts/create-xuan.ts"
    },
    "dependencies": {
        "@bestlyg/cli": "workspace:^",
        "@bestlyg/client": "workspace:^",
        "@bestlyg/server-shared": "workspace:^",
        "@bestlyg/static": "workspace:^",
        "@nestjs/common": "catalog:",
        "@nestjs/config": "catalog:",
        "@nestjs/core": "catalog:",
        "@nestjs/jwt": "catalog:",
        "@nestjs/platform-express": "catalog:",
        "@nestjs/schedule": "catalog:",
        "@nestjs/serve-static": "catalog:",
        "@nestjs/swagger": "catalog:",
        "@nestjs/typeorm": "catalog:",
        "axios": "catalog:",
        "c12": "catalog:",
        "chalk": "catalog:",
        "change-case": "catalog:",
        "compression": "catalog:",
        "cookie-parser": "catalog:",
        "dayjs": "catalog:",
        "dotenv": "catalog:",
        "express": "catalog:",
        "fs-extra": "catalog:",
        "lodash": "catalog:",
        "marked": "catalog:",
        "nest-winston": "catalog:",
        "nestjs-cls": "catalog:",
        "nodemailer": "catalog:",
        "pg": "catalog:",
        "reflect-metadata": "catalog:",
        "rxjs": "catalog:",
        "typeorm": "catalog:",
        "winston": "catalog:",
        "winston-daily-rotate-file": "catalog:",
        "zod": "catalog:"
    },
    "devDependencies": {
        "@nestjs/cli": "catalog:",
        "@nestjs/schematics": "catalog:",
        "@nestjs/testing": "catalog:",
        "@types/compression": "catalog:",
        "@types/cookie-parser": "catalog:",
        "@types/express": "catalog:",
        "@types/fs-extra": "catalog:",
        "@types/jest": "catalog:",
        "@types/lodash": "catalog:",
        "@types/node": "catalog:",
        "@types/nodemailer": "catalog:",
        "cross-env": "catalog:",
        "jest": "catalog:",
        "source-map-support": "catalog:",
        "supertest": "catalog:",
        "ts-jest": "catalog:",
        "ts-loader": "catalog:",
        "ts-node": "catalog:",
        "tsconfig-paths": "catalog:",
        "tsx": "catalog:",
        "typescript": "catalog:"
    },
    "jest": {
        "collectCoverageFrom": [
            "**/*.(t|j)s"
        ],
        "coverageDirectory": "./coverage",
        "moduleFileExtensions": [
            "js",
            "json",
            "ts"
        ],
        "moduleNameMapper": {
            "^@bestlyg-server/api(|/.*)$": "<rootDir>/libs/api/src/$1",
            "^@bestlyg-server/auth(|/.*)$": "<rootDir>/libs/auth/src/$1",
            "^@bestlyg-server/common(|/.*)$": "<rootDir>/libs/common/src/$1",
            "^@bestlyg-server/database(|/.*)$": "<rootDir>/libs/database/src/$1",
            "^@bestlyg-server/serverless(|/.*)$": "<rootDir>/libs/serverless/src/$1",
            "^@bestlyg-server/static(|/.*)$": "<rootDir>/libs/static/src/$1",
            "^@bestlyg-server/zjuer(|/.*)$": "<rootDir>/libs/zjuer/src/$1"
        },
        "passWithNoTests": true,
        "rootDir": ".",
        "roots": [
            "<rootDir>/src/",
            "<rootDir>/libs/"
        ],
        "testEnvironment": "node",
        "testRegex": ".*\\.spec\\.ts$",
        "transform": {
            "^.+\\.(t|j)s$": "ts-jest"
        }
    }
}
