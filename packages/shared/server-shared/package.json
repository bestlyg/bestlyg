{
    "name": "@bestlyg/server-shared",
    "version": "0.0.0",
    "description": "",
    "license": "ISC",
    "author": "bestlyg",
    "type": "module",
    "main": "./dist/index.cjs",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.ts",
    "typesVersions": {
        "*": {
            ".": [
                "./dist/index.d.ts"
            ]
        }
    },
    "exports": {
        "./package.json": "./package.json",
        ".": {
            "import": {
                "types": "./dist/index.d.mts",
                "default": "./dist/index.mjs"
            },
            "require": {
                "types": "./dist/index.d.cts",
                "default": "./dist/index.cjs"
            }
        },
        "./*": {
            "import": "./*",
            "require": "./*",
            "default": "./*"
        }
    },
    "scripts": {
        "build": "unbuild --config ./build.config.ts",
        "dev": "unbuild --config ./build.config.ts --watch"
    },
    "dependencies": {
        "@bestlyg/core-shared": "workspace:^",
        "crypto-js": "catalog:",
        "dayjs": "catalog:",
        "exceljs": "catalog:",
        "figlet": "catalog:",
        "fs-extra": "catalog:",
        "metadata-file": "workspace:^",
        "module-checker": "workspace:^",
        "zod": "catalog:"
    },
    "devDependencies": {
        "@types/crypto-js": "catalog:",
        "@types/figlet": "catalog:",
        "@types/fs-extra": "catalog:",
        "@types/node": "catalog:",
        "rimraf": "catalog:",
        "typescript": "catalog:",
        "unbuild": "catalog:"
    }
}
