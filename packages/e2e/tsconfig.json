{
    "compilerOptions": {
        "target": "ESNext",
        "module": "ESNext",
        "ignoreDeprecations": "6.0",
        "moduleResolution": "Bundler",
        "strict": true,
        "skipLibCheck": true,
        "allowJs": false,
        "resolveJsonModule": true,
        "esModuleInterop": true,
        "isolatedModules": true,
        "types": ["node"],
        "lib": ["ESNext", "DOM"],
        "baseUrl": ".",
        "paths": {
            "@/*": ["src/*"]
        }
    },
    "include": ["*.ts", "src/**/*.ts", "common/**/*.ts", "projects/**/*.ts"],
    "exclude": ["dist", "node_modules", "test-results", "playwright-report", "blob-report"]
}
