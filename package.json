{
    "name": "bestlyg",
    "version": "1.0.0",
    "private": true,
    "scripts": {
        "deploy": "node ./scripts/deploy.mjs",
        "build": "pnpm --filter @bestlyg/core-shared build && pnpm --filter @bestlyg/client-shared build && pnpm --filter @bestlyg/server-shared build && pnpm --filter @bestlyg/icons build && pnpm --filter @bestlyg/xidl build && pnpm --filter @bestlyg/cli build && pnpm --filter @bestlyg/client build && pnpm --filter @bestlyg/server build",
        "submodule:update": "git submodule update --init --recursive",
        "version:node": "node -v",
        "setup": "rm -rf node_modules && rm -rf ./**/node_modules && pnpm i --force",
        "lint": "oxlint packages --config ./.oxlintrc.json",
        "e2e": "pnpm --filter @bestlyg/e2e e2e",
        "e2e:run": "pnpm --filter @bestlyg/e2e e2e:run",
        "e2e:list": "pnpm --filter @bestlyg/e2e e2e:list",
        "e2e:install": "pnpm --filter @bestlyg/e2e install:browsers",
        "format": "oxfmt \"**/*.{js,jsx,tsx,ts,md,json}\" --config ./.oxfmtrc.json",
        "format:affect": "node ./scripts/format-affect.mjs",
        "commit": "git-cz",
        "commit:auto": "git pull origin master && git add -A && pnpm run commit && git push -u origin master && git push -u github master",
        "script": "zx scripts/main.mjs",
        "<!-- 快捷方式 -->": "下面是快捷方式用的",
        "c": "pnpm run commit",
        "ca": "pnpm run commit:auto"
    },
    "devDependencies": {
        "@bestlyg/cli": "workspace:^",
        "@bestlyg/server-shared": "workspace:^",
        "@changesets/cli": "catalog:",
        "@changesets/get-release-plan": "catalog:",
        "@changesets/types": "catalog:",
        "@commitlint/cli": "catalog:",
        "@commitlint/config-conventional": "catalog:",
        "@manypkg/get-packages": "catalog:",
        "dotenv": "catalog:",
        "figlet": "catalog:",
        "git-cz": "catalog:",
        "oxfmt": "catalog:",
        "oxlint": "catalog:",
        "semver": "catalog:",
        "typescript": "catalog:",
        "zx": "catalog:"
    },
    "config": {
        "commitizen": {
            "path": "cz-conventional-changelog"
        }
    },
    "packageManager": "pnpm@10.15.0"
}
